# Server Configuration
PORT=8080

# Database Configuration (PostgreSQL)
# Railway will provide these automatically via DATABASE_URL
DATABASE_URL=jdbc:postgresql://localhost:5432/omnicaredb
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT Configuration
# Generate a strong secret with: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=86400000

# CORS Configuration
# Update with your frontend URL
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Note: On Railway, set these as environment variables in the dashboard
# Do NOT commit a .env file with real credentials to Git
